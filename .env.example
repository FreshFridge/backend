PORT=3000
NODE_ENV=development
INSTANCE_ID=
RUN_SCHEDULER=true
APP_IMAGE=freshfridge-backend:latest
APP_PORT=3001
LB_PORT=3001

# JWT
JWT_ACCESS_SECRET=change_me
JWT_ACCESS_EXPIRES_IN=15m

# Admin seed
ADMIN_EMAIL=admin@freshfridge.com
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=Administrator

# MSSQL (Windows Auth OR SQL Auth)
SA_PASSWORD=change_me_StrongPassword123!
MSSQL_PID=Developer
DB_SERVER=localhost
DB_PORT=1433
DB_INSTANCE=SQLEXPRESS
DB_DATABASE=FreshFridgeDB
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_CONNECT_RETRIES=10
DB_CONNECT_RETRY_DELAY_MS=3000

# Optional Docker seed values for IoT simulator
IOT_USER_ID=11111111-1111-4111-8111-111111111111
IOT_FRIDGE_ID=22222222-2222-4222-8222-222222222222
TELEMETRY_URL=http://localhost:3001/api/iot/telemetry

# If using SQL auth:
# DB_USER=sa
# DB_PASSWORD=your_password

# If using Windows auth:
DB_TRUSTED_CONNECTION=true

# Freshness Job Configuration
FRESHNESS_JOB_INTERVAL_MS=300000
EXPIRING_SOON_DAYS=2
NOTIFICATION_COOLDOWN_HOURS=24
